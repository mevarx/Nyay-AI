# ═══════════════════════════════════════════════════════
#  NyayAI — Root .gitignore
#  This is the ONLY gitignore needed for the entire repo.
# ═══════════════════════════════════════════════════════

# ── Secrets & Env Files (CRITICAL) ────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# ── Python ────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
venv/
env/
.venv/

# ── Node / React / Next.js ────────────────────────────
node_modules/
.next/
out/
build/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
coverage/
*.tsbuildinfo
next-env.d.ts

# ── Backend runtime artifacts ─────────────────────────
nyayai-backend/cache/
nyayai-backend/uploads/
nyayai-backend/test_gemini_key.py

# ── Firebase ──────────────────────────────────────────
.firebase/
.firebaserc

# ── IDE / OS ──────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# ── Gemini / Agent artifacts ──────────────────────────
.gemini/
.agents/
.agent/
_agents/
_agent/
